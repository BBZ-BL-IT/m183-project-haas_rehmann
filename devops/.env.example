# =====================================================================
#  Shared configuration for the docker-compose stacks. Copy to `.env`:
#    cp .env.example .env
#  Compose automatically loads `.env` from this directory.
# =====================================================================

# --- Container images (pulled from Docker Hub) ---
# Override only to use a different repo/tag than the published defaults
# (t1me0n/grand-casino-{backend,frontend}:latest).
# BACKEND_IMAGE=t1me0n/grand-casino-backend:latest
# FRONTEND_IMAGE=t1me0n/grand-casino-frontend:latest

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=m183_db

# --- Kanidm (identity provider) ---
# Kanidm is reached by two names, both covered by the generated TLS cert:
#   - KANIDM_PUBLIC_ORIGIN : what the BROWSER uses (no /etc/hosts needed).
#   - KANIDM_ORIGIN        : what the BACKEND uses internally over the network.
KANIDM_PUBLIC_ORIGIN=https://localhost:8443
KANIDM_ORIGIN=https://kanidm:8443

# Demo accounts created by the provisioning step (passwords are set via a
# Kanidm credential-reset link printed during provisioning – see README).
KANIDM_ADMIN_ACCOUNT=rehmann_admin
KANIDM_USER_ACCOUNT=rehmann_user

# --- OIDC client (the backend is a confidential OAuth2 client) ---
OIDC_CLIENT_ID=m183-backend
# Where Kanidm sends the browser back after login. Must match a registered
# redirect URL and the public origin the browser actually uses. In the combined
# stack the frontend (port 8081) reverse-proxies /auth/* to the backend.
OIDC_REDIRECT_URI=http://localhost:8081/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8081/

# 64+ bytes of entropy – generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=CHANGE_ME_openssl_rand_base64_64_CHANGE_ME_CHANGE_ME_CHANGE_ME==

# Session lifetime in MINUTES (axum-oidc-client unit). 1440 = 1 day.
SESSION_MAX_AGE=1440

# Logging
RUST_LOG=info

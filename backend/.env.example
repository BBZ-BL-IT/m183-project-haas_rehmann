# --- SERVER CONFIG ---
SERVER_PORT=8080

# Controls the logging verbosity level. Options: trace, debug, info, warn, error
RUST_LOG=info

# --- DATABASE CONFIG ---
# Format: postgres://username:password@localhost:5173/database_name
DATABASE_URL=postgres://postgres:password@localhost:5432/m183_db

# --- OIDC CONFIG ---
OIDC_ISSUER_URL=https://your-identity-provider.com/realms/master

OIDC_CLIENT_ID=m183-backend-client

# CLIENT SECRETS MUST BE KEPT SECURE AT ALL COST!
OIDC_CLIENT_SECRET=super-secret-client-token-value

OIDC_REDIRECT_URI=http://localhost:8080/auth/callback

OIDC_AUTH_ENDPOINT=https://your-identity-provider.com/realms/master/protocol/openid-connect/auth

OIDC_TOKEN_ENDPOINT=https://your-identity-provider.com/realms/master/protocol/openid-connect/token

OIDC_POST_LOGOUT_REDIRECT_URI=https://your-identity-provider.com/realms/master/protocol/openid-connect/post-logout

# Where the user should be dropped off after a successful logout sequence
OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:8080/

# The private master key used to sign and encrypt session cookies.
# MUST be at least 64 bytes of high-entropy data for production.
# You can generate a valid key using: 'openssl rand -base64 64'
PRIVATE_COOKIE_KEY=wR9xK6vN2zP5Q8sB1vC4xD7yZ0w3m6p9r2u5x8y/A?D(G+KbPeShVmYq3t6w9z$C

SESSION_MAX_AGE=86400

# --- SERVER CONFIG ---
SERVER_PORT=8080

# Controls the logging verbosity level. Options: trace, debug, info, warn, error
RUST_LOG=info

# Optional: comma-separated list of browser origins allowed to call the API with
# credentials (the session cookie). Leave UNSET for a same-origin deployment
# (frontend reverse-proxied to the backend). Set it when the SPA runs on a
# different origin, e.g. the Vite dev server:
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- DATABASE CONFIG ---
# Format: postgres://username:password@host:5432/database_name
DATABASE_URL=postgres://postgres:password@localhost:5432/m183_db

# --- OIDC CONFIG (defaults below target Kanidm; see devops/README.md) ---
# Kanidm OAuth2 client ("resource server") name and its generated secret.
OIDC_CLIENT_ID=m183-backend
# CLIENT SECRETS MUST BE KEPT SECURE AT ALL COST!
OIDC_CLIENT_SECRET=super-secret-client-token-value

# Where Kanidm redirects back to after login. MUST match the registered URL and
# the host the browser actually uses. For the combined stack this is the public
# (frontend) origin which proxies /auth/* to the backend.
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback

# Kanidm OIDC endpoints. Discover them at:
#   https://<kanidm-host>/oauth2/openid/<client_id>/.well-known/openid-configuration
OIDC_AUTH_ENDPOINT=https://localhost:8443/ui/oauth2
OIDC_TOKEN_ENDPOINT=https://localhost:8443/oauth2/token
OIDC_POST_LOGOUT_REDIRECT_URI=https://localhost:8443/oauth2/openid/m183-backend/logout

# Where the user is dropped off after a successful logout.
OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:8080/

# --- ROLE / ADMIN MAPPING ---
# Token claims scanned for role/group strings, and the substring that marks an
# admin. With the provided Kanidm setup the admin lands in group
# "casino_admins@..." which contains "admin", so the defaults work as-is.
OIDC_ROLE_CLAIMS=roles,groups,scopes,scope,entitlements
OIDC_ADMIN_ROLE=admin

# The private master key used to sign and encrypt session cookies.
# MUST be at least 64 bytes of high-entropy data for production.
# Generate one with: 'openssl rand -base64 64'
PRIVATE_COOKIE_KEY=wR9xK6vN2zP5Q8sB1vC4xD7yZ0w3m6p9r2u5x8y/A?D(G+KbPeShVmYq3t6w9z$C

# Session lifetime. NOTE: axum-oidc-client interprets this as MINUTES.
# 1440 = 1 day.
SESSION_MAX_AGE=1440

# --- LOAN RULES (configurable) ---
# Max number of loans allowed per rolling window, the window length in seconds,
# and the max amount per loan. The frontend shows a countdown to when the limit
# resets (oldest loan in the window + window length).
LOAN_MAX_PER_WINDOW=3
LOAN_WINDOW_SECONDS=86400
LOAN_MAX_AMOUNT=10000

# --- SELF-REGISTRATION (optional) ---
# When set, POST /register creates a Kanidm person via a service-account API
# token (provisioned with people + group admin rights) and returns a credential
# reset link. Leave the token unset to disable registration.
KANIDM_API_URL=https://kanidm:8443
KANIDM_PUBLIC_ORIGIN=https://localhost:8443
# The registrar API token (or KANIDM_REGISTRAR_TOKEN_FILE to read it from a file).
# KANIDM_REGISTRAR_TOKEN=
KANIDM_REGISTRAR_TOKEN_FILE=/shared/registrar_token
KANIDM_REGISTER_GROUP=casino_users

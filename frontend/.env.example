# Basis-URL des Backends. Leer lassen ("") wenn das Frontend hinter demselben
# Origin läuft und /auth, /user, /spin, ... per Reverse-Proxy ans Backend gehen
# (so im kombinierten docker-compose). Für den Vite-Dev-Server gegen ein lokal
# laufendes Backend z.B. http://localhost:8080 setzen (dann CORS im Backend an).
VITE_API_BASE_URL=

# OIDC-Pfade des Backends (axum-oidc-client base_path = /auth).
# Login startet den PKCE-Flow, Logout beendet die Session.
VITE_OAUTH_LOGIN_PATH=/auth
VITE_OAUTH_LOGOUT_PATH=/auth/logout

# TEMPORÄR: solange Backend + Kanidm noch nicht laufen, true lassen.
# Für Produktion auf false setzen -> echte Backend-Calls + PKCE-Login.
VITE_USE_MOCK=true
